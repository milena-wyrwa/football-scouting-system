-- 04A. Base player dataset

SELECT
    PlayerID,
    PlayerName,
    BirthYear,
    Club,
    RatingCategory,
    Notes,
    Info,
    ScoutID,
    Adam,
    Kamil,
    Slawek,
    Wojtek
FROM players;

-- 04B. Enrichment layer (club + scout)

SELECT
    p.PlayerID,
    p.PlayerName,
    p.BirthYear,

    c.ClubName AS Klub,
    c.City AS Miasto,

    s.ScoutName AS Kto_oglądał,

    p.RatingCategory,
    p.Notes,
    p.Info,

    p.Adam,
    p.Kamil,
    p.Slawek,
    p.Wojtek

FROM players p

LEFT JOIN dim_club c
    ON p.Club = c.ClubName

LEFT JOIN dim_scout s
    ON p.ScoutID = s.ScoutID;

-- 04C. Final Looker dataset

SELECT
    e.PlayerID AS ZawodnikID,
    e.PlayerName,
    e.BirthYear,

    e.Klub,
    e.Miasto,
    e.Kto_oglądał,

    e.RatingCategory AS Ocena_kat,
    e.Notes AS Uwagi,
    e.Info AS Informacje,

    e.Adam,
    e.Kamil,
    e.Slawek,
    e.Wojtek,

    main.Positions AS Pozycja_Główna,
    alt.Positions AS Pozycja_Alternatywna

FROM enriched_players e

LEFT JOIN position_main main
    ON e.PlayerID = main.PlayerID

LEFT JOIN position_alt alt
    ON e.PlayerID = alt.PlayerID;
